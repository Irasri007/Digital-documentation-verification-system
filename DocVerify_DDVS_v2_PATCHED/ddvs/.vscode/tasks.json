{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile-ddvs",
      "type": "shell",
      "command": "javac",
      "args": [
        "-d", "${workspaceFolder}/backend/out",
        "${workspaceFolder}/backend/src/main/java/com/ddvs/*.java"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$javac"
    }
  ]
}
